interface Hito {

  era: string;

  titulo: string;

  desc: string;

  img: string;

}



const hitos: Hito[] = [

  { 

    era: "4,000 a.C.", 

    titulo: "Antiguo Egipto", 

    desc: "Descubrimiento accidental de la levadura y primeros hornos de barro.", 

    img: "https://images.unsplash.com/photo-1541167760496-1628856ab772?q=80&w=800" 

  },

  { 

    era: "100 d.C.", 

    titulo: "Imperio Romano", 

    desc: "Producción industrial, molinos de agua y creación del gremio de panaderos.", 

    img: "https://images.unsplash.com/photo-1509440159596-0249088772ff?q=80&w=800" 

  },

  { 

    era: "S. XIX", 

    titulo: "Revolución Industrial", 

