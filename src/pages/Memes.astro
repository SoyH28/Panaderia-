<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Memes Papus Bv</title>
    <style>
        :root {
            --gap: 12px;
            --radius: 10px;
        }

        body {
            margin: 0;
            padding: 20px;
            background-color: #050505;
            display: flex;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(5, 1fr); 
            gap: var(--gap); 
            width: 100%;
            max-width: 1400px;
        }

        .grid-item {
            background-color: #151515;
            aspect-ratio: 16 / 9;
            overflow: hidden;
            border-radius: var(--radius);
            cursor: pointer;
            border: 1px solid #222;
            transition: transform 0.3s ease;
        }

        .grid-item:hover {
            transform: scale(1.02);
            border-color: #555;
        }

        .grid-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        #lightbox {
            display: none;
            position: fixed;
            z-index: 9999;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: black;
            justify-content: center;
            align-items: center;
        }

        #lightbox img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            cursor: zoom-out;
        }

        #lightbox:fullscreen {
            background-color: black;
        }

        @media (max-width: 1000px) { .grid-container { grid-template-columns: repeat(3, 1fr); } }
        @media (max-width: 600px) { .grid-container { grid-template-columns: repeat(2, 1fr); } }
    </style>
</head>
<body>

    <div class="grid-container">
        <div class="grid-item"><img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSuaHNAmPDywsppYJ16z7v9nnBR2teG3E5RpA&s" alt="1"></div>
        <div class="grid-item"><img src="https://preview.redd.it/pinterest-memes-v0-t62ctrghqcbg1.jpg?width=640&crop=smart&auto=webp&s=25bb97d547a585017dd6d3a00c38ae0d2bb324bd" alt="2"></div>
        <div class="grid-item"><img src="https://www.penstagram.com/uploads/default/original/3X/b/4/b4d5a4e5c7128f127c4d20550c9dd7bb987e43a3.jpeg" alt="3"></div>
        <div class="grid-item"><img src="https://i.pinimg.com/236x/aa/b0/f7/aab0f78dcada034253ac0978b2a91041.jpg" alt="4"></div>
        <div class="grid-item"><img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQMfjR0bif3eQcrowK1BarCr699GvwJLAi4Fw&s" alt="5"></div>
    </div>

    <div id="lightbox">
        <img id="lightbox-img" src="" alt="Vista Fullscreen">
    </div>

    <script>
        const gridImages = document.querySelectorAll('.grid-item img');
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');

        gridImages.forEach((img) => {
            img.addEventListener('click', () => {
                if (lightbox && lightboxImg && img instanceof HTMLImageElement) {
                    lightboxImg.src = img.src;
                    lightbox.style.display = 'flex';

                    if (lightbox.requestFullscreen) {
                        lightbox.requestFullscreen();
                    } else if ((lightbox as any).webkitRequestFullscreen) { 
                        (lightbox as any).webkitRequestFullscreen();
                    } else if ((lightbox as any).msRequestFullscreen) {
                        (lightbox as any).msRequestFullscreen();
                    }
                }
            });
        });

        const closeFullscreen = () => {
            if (lightbox) {
                lightbox.style.display = 'none';
                if (document.fullscreenElement) {
                    document.exitFullscreen();
                }
            }
        };

        if (lightbox) {
            lightbox.addEventListener('click', closeFullscreen);
        }
        document.addEventListener('fullscreenchange', () => {
            if (!document.fullscreenElement && lightbox) {
                lightbox.style.display = 'none';
            }
        });
    </script>

</body>
</html>